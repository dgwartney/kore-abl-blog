#!/usr/bin/env bash
# Usage: bin/new-post "My Post Title"
# Creates a new draft in _drafts/ with front matter pre-filled.

set -euo pipefail

TITLE="$*"

if [[ -z "$TITLE" ]]; then
  echo "Usage: bin/new-post \"My Post Title\""
  exit 1
fi

SLUG=$(echo "$TITLE" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//')
FILE="_drafts/${SLUG}.md"

if [[ -f "$FILE" ]]; then
  echo "Draft already exists: $FILE"
  exit 1
fi

cat > "$FILE" <<EOF
---
title: "$TITLE"
date: $(date +"%Y-%m-%d %H:%M:%S %z")
categories: [ABL]
tags: []
---

<!-- Write your post here. Remove this comment when done. -->
EOF

echo "Draft created: $FILE"
echo ""
echo "Preview:  bundle exec jekyll serve --drafts"
echo "Publish:  mv $FILE _posts/$(date +%Y-%m-%d)-${SLUG}.md"
